# Copy to .env and fill in your values
# Required for production — defaults work for local dev

# Database (overridden to postgres in docker-compose)
DATABASE_URL=sqlite+aiosqlite:///./figureout.db

# Teacher auth (single admin password for MVP)
TEACHER_ADMIN_PASSWORD=admin123

# JWT secret — CHANGE THIS in production
SECRET_KEY=change-me-in-production-secret-key-at-least-32-chars

# OpenAI (optional — MockProvider is used if not set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Environment
ENVIRONMENT=development
